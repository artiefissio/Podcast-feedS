# Copy to /etc/podcast-feedS.env on the VPS and adjust as needed.
RETENTION_DAYS=14
GITHUB_PUSH=true
PUBLISH_REMOTE=origin
PUBLISH_BRANCH=gh-pages
STREAM_URL=https://ktal.broadcasttool.stream/stream
AUDIO_BITRATE=192k
FFMPEG_BIN=/usr/bin/ffmpeg
FFPROBE_BIN=/usr/bin/ffprobe

# Optional only on macOS hosts. Leave blank on Linux/VPS.
IMESSAGE_NUMBER=
