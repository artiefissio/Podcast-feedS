[Unit]
Description=Run podcast recorder on the KTAL show schedule

[Timer]
OnCalendar=Sat *-*-* 17:00:00
OnCalendar=Sat *-*-* 18:00:00
OnCalendar=Sat *-*-* 19:00:00
OnCalendar=Sat *-*-* 20:00:00
OnCalendar=Sat *-*-* 21:00:00
OnCalendar=Sun *-*-* 16:00:00
OnCalendar=Mon *-*-* 20:00:00
AccuracySec=1s

[Install]
WantedBy=timers.target
